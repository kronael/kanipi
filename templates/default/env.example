# kanipi instance configuration
# Copy to ${PREFIX}/data/kanipi_<name>/.env and edit.
# PREFIX defaults to /srv if unset.

# --- Identity ---
ASSISTANT_NAME=
# Set true if agent has its own phone number (skips self-message filtering)
#ASSISTANT_HAS_OWN_NUMBER=false

# --- Channels (enable by setting token/credentials) ---
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
# WhatsApp: enabled when store/auth/creds.json exists (QR pairing)

# Email channel
#EMAIL_IMAP_HOST=
#EMAIL_SMTP_HOST=
#EMAIL_ACCOUNT=
#EMAIL_PASSWORD=

# --- Agent container ---
CONTAINER_IMAGE=kanipi-agent:latest
# Claude Code OAuth token (from `claude login`) or set ANTHROPIC_API_KEY instead.
# Each agent invocation uses API credits. Tune IDLE_TIMEOUT and
# MAX_CONCURRENT_CONTAINERS to control cost.
CLAUDE_CODE_OAUTH_TOKEN=
# Max time (ms) before killing idle container (default: 1800000 = 30min)
IDLE_TIMEOUT=300000
# Max concurrent agent containers (default: 5)
MAX_CONCURRENT_CONTAINERS=3
# Max time (ms) for a single container run (default: 1800000 = 30min)
#CONTAINER_TIMEOUT=1800000
# Max output size in bytes (default: 10485760 = 10MB)
#CONTAINER_MAX_OUTPUT_SIZE=10485760

# --- Media processing ---
# Enable attachment download pipeline (PDF, images, etc.)
#MEDIA_ENABLED=true
# Max attachment size in bytes (default: 52428800 = 50MB)
#MEDIA_MAX_FILE_BYTES=52428800
# Enable voice message transcription via Whisper
#VOICE_TRANSCRIPTION_ENABLED=true
# Whisper API endpoint (default: http://localhost:8080)
#WHISPER_BASE_URL=http://localhost:8080
# Whisper model (default: turbo)
#WHISPER_MODEL=turbo
# Enable video transcription (audio extraction + whisper)
#VIDEO_TRANSCRIPTION_ENABLED=false

# --- Web interface ---
# External web port (vite runs on internal port automatically)
WEB_PORT=5173
# Public hostname for web links (e.g., myhost.example.com)
WEB_HOST=
# Allow unauthenticated web access
#WEB_PUBLIC=false

# --- Web authentication ---
# JWT secret for session auth (required for non-public web mode)
AUTH_SECRET=
# OAuth providers (optional)
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=
#DISCORD_CLIENT_ID=
#DISCORD_CLIENT_SECRET=

# --- Rate limiting (slink anonymous/authenticated) ---
#SLINK_ANON_RPM=10
#SLINK_AUTH_RPM=60

# --- File transfer (agent↔user file exchange) ---
#FILE_TRANSFER_ENABLED=false
#FILE_DENY_GLOBS=.git/**,.env,.envrc,**/*.pem
#FILE_MAX_UPLOAD_BYTES=20971520
#FILE_MAX_DOWNLOAD_BYTES=52428800

# --- Logging ---
#LOG_LEVEL=info
