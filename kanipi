#!/bin/bash
set -e

group_cmd() {
  local INST="$1" ACTION="$2" JID="$3" FOLDER="$4"
  local DATA="/srv/data/kanipi_${INST}"
  local DB="$DATA/store/messages.db"

  if [ ! -f "$DB" ]; then
    if [ "$ACTION" = "add" ]; then
      mkdir -p "$(dirname "$DB")"
      node -e "
        const Database = require('better-sqlite3');
        const db = new Database('$DB');
        db.exec(\`
          CREATE TABLE IF NOT EXISTS chats (
            jid TEXT PRIMARY KEY, name TEXT,
            last_message_time TEXT, channel TEXT,
            is_group INTEGER DEFAULT 0
          );
          CREATE TABLE IF NOT EXISTS registered_groups (
            jid TEXT PRIMARY KEY, name TEXT NOT NULL,
            folder TEXT NOT NULL UNIQUE,
            trigger_pattern TEXT NOT NULL,
            added_at TEXT NOT NULL,
            container_config TEXT,
            requires_trigger INTEGER DEFAULT 1
          );
        \`);
        db.close();
      "
    else
      echo "no db: $DB"
      exit 1
    fi
  fi

  case "$ACTION" in
    list)
      node -e "
        const Database = require('better-sqlite3');
        const db = new Database('$DB', { readonly: true });
        const groups = db.prepare('SELECT jid, name, folder, requires_trigger FROM registered_groups').all();
        const chats = db.prepare('SELECT jid, name, channel FROM chats WHERE is_group = 1').all();
        const registered = new Set(groups.map(g => g.jid));
        console.log('registered:');
        if (!groups.length) console.log('  (none)');
        for (const g of groups) {
          const rt = g.requires_trigger ? 'trigger' : 'direct';
          console.log('  ' + g.jid + '  ' + g.folder + '  ' + rt + (g.name ? '  ' + g.name : ''));
        }
        const discovered = chats.filter(c => !registered.has(c.jid));
        if (discovered.length) {
          console.log('discovered:');
          for (const c of discovered) {
            console.log('  ' + c.jid + '  ' + (c.channel || '') + '  ' + (c.name || ''));
          }
        }
        db.close();
      "
      ;;
    add)
      if [ -z "$JID" ]; then
        echo "usage: kanipi <instance> group add <jid> [folder]"
        exit 1
      fi
      local ASSISTANT
      ASSISTANT=$(grep -s '^ASSISTANT_NAME=' "$DATA/.env" | cut -d= -f2- || echo "$INST")
      F=$(node -e "
        const Database = require('better-sqlite3');
        const crypto = require('crypto');
        const db = new Database('$DB');
        // ensure slink_token column exists (in case DB was created before migration)
        try { db.exec('ALTER TABLE registered_groups ADD COLUMN slink_token TEXT'); } catch {}
        const count = db.prepare('SELECT COUNT(*) as n FROM registered_groups').get().n;
        const folder = '$FOLDER' || (count === 0 ? 'main' : '');
        if (!folder) { console.error('folder required (not first group)'); process.exit(1); }
        const rt = count === 0 ? 0 : 1;
        const trigger = rt ? '@$ASSISTANT' : '';
        const now = new Date().toISOString();
        const isWeb = '$JID'.startsWith('web:');
        const slinkToken = isWeb ? crypto.randomBytes(12).toString('base64url') : null;
        db.prepare(
          'INSERT OR REPLACE INTO registered_groups (jid, name, folder, trigger_pattern, added_at, container_config, requires_trigger, slink_token) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
        ).run('$JID', folder, folder, trigger, now, null, rt, slinkToken);
        if (isWeb && slinkToken) {
          process.stdout.write(folder + '\t' + slinkToken + '\n');
        } else {
          process.stdout.write(folder + '\n');
        }
        db.close();
      ")
      FOLDER_NAME=$(echo "$F" | cut -f1)
      SLINK_TOKEN=$(echo "$F" | cut -f2 -s)
      echo "added: $JID → $FOLDER_NAME"
      if [ -n "$SLINK_TOKEN" ]; then
        WEB_HOST_VAL=$(grep -s '^WEB_HOST=' "$DATA/.env" | cut -d= -f2- || true)
        echo "slink token: $SLINK_TOKEN  url: https://${WEB_HOST_VAL:-<WEB_HOST>}/pub/s/$SLINK_TOKEN"
      fi
      mkdir -p "$DATA/groups/$FOLDER_NAME/logs"
      ;;
    rm)
      if [ -z "$JID" ]; then
        echo "usage: kanipi <instance> group rm <jid>"
        exit 1
      fi
      node -e "
        const Database = require('better-sqlite3');
        const db = new Database('$DB');
        const row = db.prepare('SELECT folder FROM registered_groups WHERE jid = ?').get('$JID');
        if (!row) { console.error('not found: $JID'); process.exit(1); }
        if (row.folder === 'main') { console.error('refused: cannot remove main group'); process.exit(1); }
        db.prepare('DELETE FROM registered_groups WHERE jid = ?').run('$JID');
        console.log('removed: $JID (folder kept: groups/' + row.folder + ')');
        db.close();
      "
      ;;
    *)
      echo "unknown action: $ACTION"
      echo "usage: kanipi <instance> group {list|add|rm} ..."
      exit 1
      ;;
  esac
}

if [ "${1:-}" = "config" ]; then
  INST="${2:-}"
  if [ -z "$INST" ] || [ "${3:-}" != "group" ]; then
    echo "usage: kanipi config <instance> group {list|add|rm} ..."
    exit 1
  fi
  group_cmd "$INST" "${4:-}" "${5:-}" "${6:-}"
  exit 0
fi

if [ "${1:-}" = "create" ]; then
  NAME="${2:-}"
  if [ -z "$NAME" ]; then
    echo "usage: kanipi create <name>"
    exit 1
  fi

  DATA="/srv/data/kanipi_${NAME}"
  if [ -d "$DATA" ]; then
    echo "exists: $DATA"
    exit 1
  fi

  mkdir -p "$DATA/groups/main/logs" \
           "$DATA/store" \
           "$DATA/data" \
           "$DATA/web" \
           "/srv/run/kanipi_${NAME}"
  # Gateway and agent containers run as uid/gid 1000 (node)
  chown -R 1000:1000 "$DATA/groups" "$DATA/data"

  # seed .env from template
  SEED="${APP_DIR:-/srv/app}/template"
  [ ! -d "$SEED" ] && SEED="$(cd "$(dirname "$0")" && pwd)/template"
  cp "$SEED/env.example" "$DATA/.env"
  sed -i "s/^ASSISTANT_NAME=.*/ASSISTANT_NAME=${NAME}/" "$DATA/.env"
  SLOTH_PASS=$(openssl rand -hex 8 2>/dev/null || tr -dc a-z0-9 < /dev/urandom | head -c 16)
  sed -i "s/^SLOTH_USERS=.*/SLOTH_USERS=admin:${SLOTH_PASS}/" "$DATA/.env"
  echo "created: $DATA/.env"

  # seed web template
  if [ -d "$SEED/web" ]; then
    cp -rn "$SEED/web/." "$DATA/web/"
    cd "$DATA/web" && npm install --silent 2>/dev/null || true
  fi

  SERVICE="$DATA/kanipi_${NAME}.service"
  cat > "$SERVICE" <<SVC
[Unit]
Description=kanipi ${NAME}
After=docker.service
Requires=docker.service

[Service]
StartLimitInterval=0
StartLimitBurst=100
RestartSec=1
TimeoutStartSec=infinity
Restart=always

ExecStartPre=-/usr/bin/docker stop %n
ExecStartPre=-/usr/bin/docker rm -f %n
ExecStop=/usr/bin/docker rm -f %n
ExecStart=/usr/bin/docker run -i --rm --name %n \
    --network=host \
    -v /srv/data/kanipi_${NAME}:/srv/app/home \
    -v /srv/run/kanipi_${NAME}:/srv/run/kanipi_${NAME} \
    -v /var/run/docker.sock:/var/run/docker.sock \
    kanipi \
    ./kanipi ${NAME}

SyslogIdentifier=kanipi_${NAME}
SyslogFacility=local3

[Install]
WantedBy=default.target
SVC
  echo "generated: $SERVICE"
  echo ""
  echo "next:"
  echo "  1. edit $DATA/.env  (TELEGRAM_BOT_TOKEN)"
  echo "  2. make image && make agent-image"
  exit 0
fi

if [ -z "${1:-}" ]; then
  echo "usage: kanipi <instance>"
  echo "       kanipi create <name>"
  echo "       kanipi <instance> group {list|add|rm} ..."
  exit 1
fi

if [ "${2:-}" = "group" ]; then
  group_cmd "$1" "${3:-}" "${4:-}" "${5:-}"
  exit 0
fi

INSTANCE="$1"
HOME_DIR="/srv/app/home"

if [ ! -f "$HOME_DIR/.env" ]; then
  echo "no .env in $HOME_DIR"
  exit 1
fi

cd "$HOME_DIR"

# sync source into home dir so agent containers can mount it as /workspace/self
cp -r /srv/app/container/. ./container/
cp -r /srv/app/template/. ./template/

# read web config from .env
# WEB_PORT is the external port (proxy). Vite runs on WEB_PORT+1 (localhost only).
# Falls back to VITE_PORT for backward compat with old instances.
WEB_PORT=$(grep -s '^WEB_PORT=' .env | cut -d= -f2- || true)
[ -z "$WEB_PORT" ] && WEB_PORT=$(grep -s '^VITE_PORT=' .env | cut -d= -f2- || true)
WEB_HOST=$(grep -s '^WEB_HOST=' .env | cut -d= -f2- || true)
[ -n "$WEB_HOST" ] && export WEB_HOST

if [ -n "$WEB_PORT" ]; then
  # internal vite port: same suffix as WEB_PORT but in 48xxx range
  _suffix=$(( WEB_PORT % 1000 ))
  VITE_PORT_INTERNAL=$(( 48000 + _suffix ))
  export VITE_PORT_INTERNAL
fi

# install web deps if missing
if [ -n "$WEB_PORT" ] && [ -d web ] && [ ! -d web/node_modules ]; then
  cd web && npm install --silent 2>/dev/null && cd "$HOME_DIR"
fi

# start gateway
node /srv/app/dist/index.js &
GATEWAY=$!

# start vite on internal port if configured (proxy in gateway handles external port)
if [ -n "$WEB_PORT" ] && [ -d web ]; then
  mkdir -p /srv/app/tmp
  (while true
  do
    cd "$HOME_DIR/web" && npx vite --host 127.0.0.1 --port "$VITE_PORT_INTERNAL" &
    echo $! > /srv/app/tmp/vite.pid
    wait $!
    sleep 1
  done) &
  VITE=$!
  trap 'kill $GATEWAY $VITE 2>/dev/null; wait' INT TERM
else
  trap 'kill $GATEWAY 2>/dev/null; wait' INT TERM
fi

wait $GATEWAY
[ -n "${VITE:-}" ] && kill $VITE 2>/dev/null
wait
