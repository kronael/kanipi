#!/bin/bash
set -e

if [ "${1:-}" = "group" ]; then
  ACTION="${2:-}"
  INST="${3:-}"

  if [ -z "$ACTION" ] || [ -z "$INST" ]; then
    echo "usage: kanipi group list <instance>"
    echo "       kanipi group add <instance> <jid> [folder]"
    echo "       kanipi group rm <instance> <jid>"
    exit 1
  fi

  DATA="/srv/data/kanipi_${INST}"
  DB="$DATA/store/messages.db"

  if [ ! -f "$DB" ]; then
    if [ "$ACTION" = "add" ]; then
      mkdir -p "$(dirname "$DB")"
      node -e "
        const Database = require('better-sqlite3');
        const db = new Database('$DB');
        db.exec(\`
          CREATE TABLE IF NOT EXISTS chats (
            jid TEXT PRIMARY KEY, name TEXT,
            last_message_time TEXT, channel TEXT,
            is_group INTEGER DEFAULT 0
          );
          CREATE TABLE IF NOT EXISTS registered_groups (
            jid TEXT PRIMARY KEY, name TEXT NOT NULL,
            folder TEXT NOT NULL UNIQUE,
            trigger_pattern TEXT NOT NULL,
            added_at TEXT NOT NULL,
            container_config TEXT,
            requires_trigger INTEGER DEFAULT 1
          );
        \`);
        db.close();
      "
    else
      echo "no db: $DB"
      exit 1
    fi
  fi

  case "$ACTION" in
    list)
      node -e "
        const Database = require('better-sqlite3');
        const db = new Database('$DB', { readonly: true });
        const groups = db.prepare('SELECT jid, name, folder, requires_trigger FROM registered_groups').all();
        const chats = db.prepare('SELECT jid, name, channel FROM chats WHERE is_group = 1').all();
        const registered = new Set(groups.map(g => g.jid));
        console.log('registered:');
        if (!groups.length) console.log('  (none)');
        for (const g of groups) {
          const rt = g.requires_trigger ? 'trigger' : 'direct';
          console.log('  ' + g.jid + '  ' + g.folder + '  ' + rt + (g.name ? '  ' + g.name : ''));
        }
        const discovered = chats.filter(c => !registered.has(c.jid));
        if (discovered.length) {
          console.log('discovered:');
          for (const c of discovered) {
            console.log('  ' + c.jid + '  ' + (c.channel || '') + '  ' + (c.name || ''));
          }
        }
        db.close();
      "
      ;;
    add)
      JID="${4:-}"
      FOLDER="${5:-}"
      if [ -z "$JID" ]; then
        echo "usage: kanipi group add <instance> <jid> [folder]"
        exit 1
      fi
      ASSISTANT=$(grep -s '^ASSISTANT_NAME=' "$DATA/.env" | cut -d= -f2- || echo "$INST")
      F=$(node -e "
        const Database = require('better-sqlite3');
        const db = new Database('$DB');
        const count = db.prepare('SELECT COUNT(*) as n FROM registered_groups').get().n;
        const folder = '$FOLDER' || (count === 0 ? 'main' : '');
        if (!folder) { console.error('folder required (not first group)'); process.exit(1); }
        const rt = count === 0 ? 0 : 1;
        const trigger = rt ? '@$ASSISTANT' : '';
        const now = new Date().toISOString();
        db.prepare(
          'INSERT OR REPLACE INTO registered_groups (jid, name, folder, trigger_pattern, added_at, container_config, requires_trigger) VALUES (?, ?, ?, ?, ?, ?, ?)'
        ).run('$JID', folder, folder, trigger, now, null, rt);
        console.log(folder);
        db.close();
      ")
      echo "added: $JID → $F"
      mkdir -p "$DATA/groups/$F/logs"
      ;;
    rm)
      JID="${4:-}"
      if [ -z "$JID" ]; then
        echo "usage: kanipi group rm <instance> <jid>"
        exit 1
      fi
      node -e "
        const Database = require('better-sqlite3');
        const db = new Database('$DB');
        const row = db.prepare('SELECT folder FROM registered_groups WHERE jid = ?').get('$JID');
        if (!row) { console.error('not found: $JID'); process.exit(1); }
        if (row.folder === 'main') { console.error('refused: cannot remove main group'); process.exit(1); }
        db.prepare('DELETE FROM registered_groups WHERE jid = ?').run('$JID');
        console.log('removed: $JID (folder kept: groups/' + row.folder + ')');
        db.close();
      "
      ;;
    *)
      echo "unknown action: $ACTION"
      echo "usage: kanipi group {list|add|rm} <instance> ..."
      exit 1
      ;;
  esac
  exit 0
fi

if [ "${1:-}" = "create" ]; then
  NAME="${2:-}"
  if [ -z "$NAME" ]; then
    echo "usage: kanipi create <name>"
    exit 1
  fi

  DATA="/srv/data/kanipi_${NAME}"
  if [ -d "$DATA" ]; then
    echo "exists: $DATA"
    exit 1
  fi

  mkdir -p "$DATA/groups/main/logs" \
           "$DATA/store" \
           "$DATA/data" \
           "$DATA/web" \
           "/srv/run/kanipi_${NAME}"

  # seed .env from template
  SEED="/srv/app/template"
  cp "$SEED/env.example" "$DATA/.env"
  sed -i "s/^ASSISTANT_NAME=.*/ASSISTANT_NAME=${NAME}/" "$DATA/.env"
  echo "created: $DATA/.env"

  # seed web template
  if [ -d "$SEED/web" ]; then
    cp -rn "$SEED/web/." "$DATA/web/"
    cd "$DATA/web" && npm install --silent 2>/dev/null || true
  fi

  SERVICE="$DATA/kanipi_${NAME}.service"
  cat > "$SERVICE" <<SVC
[Unit]
Description=kanipi ${NAME}
After=docker.service
Requires=docker.service

[Service]
StartLimitInterval=0
StartLimitBurst=100
RestartSec=1
TimeoutStartSec=infinity
Restart=always

ExecStartPre=-/usr/bin/docker stop %n
ExecStartPre=-/usr/bin/docker rm -f %n
ExecStop=/usr/bin/docker rm -f %n
ExecStart=/usr/bin/docker run -i --rm --name %n \
    --network=host \
    -v /srv/data/kanipi_${NAME}:/srv/app/home \
    -v /srv/run/kanipi_${NAME}:/srv/run/kanipi_${NAME} \
    -v /var/run/docker.sock:/var/run/docker.sock \
    kanipi \
    ./kanipi ${NAME}

SyslogIdentifier=kanipi_${NAME}
SyslogFacility=local3

[Install]
WantedBy=default.target
SVC
  echo "generated: $SERVICE"
  echo ""
  echo "next:"
  echo "  1. edit $DATA/.env  (TELEGRAM_BOT_TOKEN)"
  echo "  2. make image && make agent-image"
  exit 0
fi

if [ -z "${1:-}" ]; then
  echo "usage: kanipi <instance>"
  echo "       kanipi create <name>"
  echo "       kanipi group {list|add|rm} <instance> ..."
  exit 1
fi

INSTANCE="$1"
HOME_DIR="/srv/app/home"

if [ ! -f "$HOME_DIR/.env" ]; then
  echo "no .env in $HOME_DIR"
  exit 1
fi

cd "$HOME_DIR"

# read web config from .env
VITE_PORT=$(grep -s '^VITE_PORT=' .env | cut -d= -f2- || true)
WEB_HOST=$(grep -s '^WEB_HOST=' .env | cut -d= -f2- || true)
[ -n "$WEB_HOST" ] && export WEB_HOST

# install web deps if missing
if [ -n "$VITE_PORT" ] && [ -d web ] && [ ! -d web/node_modules ]; then
  cd web && npm install --silent 2>/dev/null && cd "$HOME_DIR"
fi

# start gateway
node /srv/app/dist/index.js &
GATEWAY=$!

# start vite if configured
if [ -n "$VITE_PORT" ] && [ -d web ]; then
  mkdir -p /srv/app/tmp
  (while true
  do
    cd "$HOME_DIR/web" && npx vite --host 0.0.0.0 --port "$VITE_PORT" &
    echo $! > /srv/app/tmp/vite.pid
    wait $!
    sleep 1
  done) &
  VITE=$!
  trap 'kill $GATEWAY $VITE 2>/dev/null; wait' INT TERM
else
  trap 'kill $GATEWAY 2>/dev/null; wait' INT TERM
fi

wait $GATEWAY
[ -n "${VITE:-}" ] && kill $VITE 2>/dev/null
wait
